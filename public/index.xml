      <pubDate>Sat, 09 May 2026 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/photography/2026-05-levellers-day/</guid>
        <media:content url="http://localhost:1313/photography/2026-05-levellers-day/2026-05-09-121107-Luigi-Marini-1068x1600_hu_e22b6a4ce608056d.webp" type="image/jpeg"/>
        <description>
